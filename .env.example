# Core app
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bigbankbonus
ADMIN_SECRET=replace-with-a-long-random-string
PORT=8080

# Public domain used by the mobile app and Plaid redirect flows
EXPO_PUBLIC_DOMAIN=localhost:8080

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_MONTHLY=price_replace_monthly
STRIPE_PRICE_ANNUAL=price_replace_annual
EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER=merchant.com.bigbankbonus

# Plaid
PLAID_CLIENT_ID=replace_me
PLAID_SECRET=replace_me
PLAID_ENV=sandbox
# Required for OAuth-style institutions and mobile browser return flows.
PLAID_REDIRECT_URI=https://localhost:8080/plaid-callback

# Email — Resend (recommended: resend.com, free 3k/mo)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# SMTP_FROM=noreply@bigbankbonus.com

# Email — SendGrid alternative
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your_api_key_here
# SMTP_FROM=noreply@bigbankbonus.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bigbankbonus.com

# SMS — Twilio (optional, twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AI Agent — OpenAI (optional, platform.openai.com)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=
