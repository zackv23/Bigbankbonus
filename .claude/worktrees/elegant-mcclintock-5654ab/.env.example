# Core app
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bigbankbonus
ADMIN_SECRET=replace-with-a-long-random-string
PORT=8080

# Public domain used by the mobile app and Plaid redirect flows
EXPO_PUBLIC_DOMAIN=localhost:8080

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_MONTHLY=price_replace_monthly
STRIPE_PRICE_ANNUAL=price_replace_annual
EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER=merchant.com.bigbankbonus

# Plaid
PLAID_CLIENT_ID=replace_me
PLAID_SECRET=replace_me
PLAID_ENV=sandbox
# Required for OAuth-style institutions and mobile browser return flows.
PLAID_REDIRECT_URI=https://localhost:8080/plaid-callback

# Optional notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bigbankbonus.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
